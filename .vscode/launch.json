{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Flask",
      "type": "debugpy",
      "request": "launch",
      "module": "flask", // Указываем модуль Flask
      "env": {
        "FLASK_APP": "run.py", // Путь к вашему файлу приложения
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "args": ["run", "--no-debugger", "--no-reload"], // Отключаем встроенный отладчик Flask и перезагрузку
      "justMyCode": true // Отладчик будет останавливаться только в вашем коде, а не в библиотеках
    }
  ]
}